{
  "name": "kwalify-api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "node scripts/prepare-dist.mjs && node node_modules/typescript/bin/tsc && node backend/dist/scripts/scene-cohesion-human-save-gate.js",
    "start": "node backend/dist/server.js",
    "typecheck": "tsc --noEmit",
    "smoke:static": "node scripts/smoke-static.mjs",
    "evaluation:playlists": "npm run build && node backend/dist/scripts/playlist-evaluation-harness.js",
    "evaluation:overnight": "npm run build && node backend/dist/scripts/playlist-evaluation-harness.js --benchmark-size 250 --out reports/playlist-evaluation/overnight-live --timeout-ms 120000 --concurrency 1 --delay-ms 2500 --max-http-retries 2 --max-failures 35 --cluster-fail-fast 0 --checkpoint-every 1 --fresh",
    "evaluation:overnight:resume": "npm run build && node backend/dist/scripts/playlist-evaluation-harness.js --benchmark-size 250 --out reports/playlist-evaluation/overnight-live --timeout-ms 120000 --concurrency 1 --delay-ms 2500 --max-http-retries 2 --max-failures 35 --cluster-fail-fast 0 --checkpoint-every 1 --resume",
    "benchmark:prompt-reliability": "npm run build && node backend/dist/scripts/prompt-reliability-benchmark.js",
    "regression:prompt-reliability": "npm run build && node backend/dist/scripts/prompt-reliability-regression.js",
    "regression:playlists": "npm run build && node backend/dist/scripts/playlist-regression-guard.js",
    "ci:prompt-reliability-local": "npm run build && node backend/dist/scripts/prompt-reliability-local-fixtures.js",
    "ci:prompt-reliability": "npm run build && node backend/dist/scripts/prompt-reliability-ci-gate.js",
    "audit:product-behavior": "npm run build && node backend/dist/scripts/playlist-product-behavior-audit.js",
    "audit:system-observability": "npm run build && node backend/dist/scripts/playlist-system-observability-audit.js",
    "quality:eval": "npm run build && node backend/dist/scripts/playlist-quality-eval.js",
    "quality:stress": "npm run build && node backend/dist/scripts/playlist-stress-report.js",
    "smoke:deploy": "npm run build && node backend/dist/scripts/deploy-smoke.js",
    "smoke:shutdown": "npm run build && node backend/dist/scripts/shutdown-smoke.js",
    "verify:eval-token": "npm run build && node backend/dist/scripts/verify-eval-token.js",
    "validate:benchmark-env": "npm run build && node backend/dist/scripts/validate-benchmark-env.js",
    "diagnose:eval-token": "npm run build && node backend/dist/scripts/diagnose-eval-token.js",
    "sync:eval-token": "powershell -ExecutionPolicy Bypass -File scripts/sync-eval-token.ps1",
    "rotate:eval-token": "powershell -ExecutionPolicy Bypass -File scripts/rotate-eval-token.ps1",
    "harvest:unknown-terms": "npm run build && node backend/dist/scripts/harvest-unknown-terms.js",
    "promote:aliases": "npm run build && node backend/dist/scripts/promote-harvested-aliases.js",
    "promote:aliases:apply": "npm run build && node backend/dist/scripts/promote-harvested-aliases.js -- --apply",
    "coherence:intent": "npm run build && node backend/dist/scripts/coherence-intent-fixtures.js",
    "coherence:intent-contract-ssot": "npm run build && node backend/dist/scripts/coherence-intent-contract-ssot-fixtures.js",
    "coherence:playlist": "npm run build && node backend/dist/scripts/coherence-playlist-fixtures.js",
    "coherence:world-boundary": "npm run build && node backend/dist/scripts/coherence-world-boundary-fixtures.js",
    "coherence:uk-hip-hop": "npm run build && node backend/dist/scripts/coherence-uk-hip-hop-fixtures.js",
    "coherence:taxonomy": "npm run build && node backend/dist/scripts/coherence-taxonomy-correlation-fixtures.js",
    "coherence:semantic-collisions": "npm run build && node backend/dist/scripts/coherence-semantic-collision-fixtures.js",
    "coherence:electronic-subgenres": "npm run build && node backend/dist/scripts/coherence-electronic-subgenre-fixtures.js",
    "benchmark:pairwise-signatures": "npm run build && node backend/dist/scripts/pairwise-signature-benchmark.js",
    "backfill:audio-features": "npm run build && node backend/dist/scripts/audio-feature-backfill.js",
    "coherence:recovery-finalization": "npm run build && node backend/dist/scripts/coherence-recovery-finalization-fixtures.js",
    "coherence:cultural-references": "npm run build && node backend/dist/scripts/coherence-cultural-reference-fixtures.js",
    "benchmark:cultural-references": "npm run build && node backend/dist/scripts/cultural-reference-benchmark.js",
    "benchmark:scene-knowledge": "npm run build && node backend/dist/scripts/scene-knowledge-accuracy-benchmark.js",
    "discover:scene-gaps": "npm run build && node backend/dist/scripts/discover-scene-knowledge-gaps.js",
    "audit:semantic-overfitting": "npm run build && node backend/dist/scripts/semantic-overfitting-audit.js",
    "coherence:taste-preservation": "npm run build && node backend/dist/scripts/coherence-taste-preservation-fixtures.js",
    "benchmark:library-anchored-scenes": "npm run build && node backend/dist/scripts/library-anchored-scenes-benchmark.js",
    "benchmark:deep-music-semantics": "npm run build && node backend/dist/scripts/deep-music-semantics-benchmark.js",
    "stress:adversarial": "npm run build && node backend/dist/scripts/adversarial-prompt-stress-test.js",
    "stress:adversarial:ci": "npm run build && node backend/dist/scripts/adversarial-prompt-stress-test.js --limit 100",
    "stress:cross-library": "npm run build && node backend/dist/scripts/cross-library-robustness-test.js",
    "stress:identity-preservation": "npm run build && node backend/dist/scripts/identity-preservation-stress-test.js",
    "benchmark:scene-collisions": "npm run build && node backend/dist/scripts/scene-collision-benchmark.js",
    "coherence:scene-filter": "npm run build && node backend/dist/scripts/coherence-scene-filter-fixtures.js",
    "coherence:scene-world": "npm run build && node backend/dist/scripts/scene-world-fixtures.js",
    "audit:human-save": "npm run build && node backend/dist/scripts/human-save-audit.js",
    "benchmark:human-saveability-overnight": "npm run build && node backend/dist/scripts/human-saveability-overnight-benchmark.js",
    "test:observability-invariants": "npm run build && node --test backend/dist/tests/observability-invariants.test.js",
    "test:observability-completeness": "npm run build && node --test backend/dist/tests/observability-completeness.test.js",
    "test:editorial-polish-layer": "npm run build && node --test backend/dist/tests/editorial-polish-layer.test.js",
    "test:editorial-stabiliser": "npm run build && node --test backend/dist/tests/editorial-stabiliser.test.js",
    "test:intent-collapse-layer": "npm run build && node --test backend/dist/tests/intent-collapse-layer.test.js",
    "test:editorial-roi": "npm run build && node --test backend/dist/tests/editorial-roi.test.js",
    "analyze:human-saveability-failures": "npm run build && node backend/dist/scripts/human-saveability-failure-analysis.js",
    "benchmark:human-saveability-before-after": "npm run build && node backend/dist/scripts/human-saveability-before-after.js",
    "investigate:dominant-cluster-funnel": "npm run build && node backend/dist/scripts/dominant-cluster-funnel-investigation.js",
    "investigate:opening-ten-trace": "npm run build && node backend/dist/scripts/opening-ten-trace-investigation.js",
    "investigate:intent-collapse-root-cause": "npm run build && node backend/dist/scripts/intent-collapse-root-cause-analysis.js",
    "trace:benchmark-attribution": "npm run build && node backend/dist/scripts/benchmark-attribution-trace.js",
    "ci:scene-cohesion-human-save": "npm run build && node backend/dist/scripts/scene-cohesion-human-save-gate.js",
    "proof:scene-world": "npm run build && node backend/dist/scripts/scene-world-proof.js",
    "regression:human-save": "node scripts/human-save-regression.mjs",
    "proof:production": "node scripts/run-production-proof-suite.mjs",
    "coherence:truthful-metrics": "npm run build && node backend/dist/scripts/truthful-metrics-fixtures.js",
    "audit:benchmarks": "npm run build && node backend/dist/scripts/real-vs-synthetic-benchmark-auditor.js",
    "audit:benchmarks:ci": "npm run build && node backend/dist/scripts/real-vs-synthetic-benchmark-auditor.js --ci --limit 100",
    "audit:benchmarks:strict": "npm run build && node backend/dist/scripts/real-vs-synthetic-benchmark-auditor.js --ci --strict --limit 100",
    "ci:semantic-scenes": "npm run build && node backend/dist/scripts/semantic-scene-ci-gate.js",
    "regression:coherence-live": "npm run build && node backend/dist/scripts/coherence-live-regression.js",
    "smoke:spotify-user-id": "node scripts/resolve-smoke-spotify-user-id.mjs",
    "validation:production": "npm run build && node backend/dist/scripts/production-validation.js",
    "ci:convergence-overlap": "npm run build && node backend/dist/scripts/convergence-overlap-ci-gate.js",
    "ci:frontend-modules": "npm run build && node backend/dist/scripts/frontend-module-ci-gate.js",
    "report:prompt-reliability-trend": "npm run build && node backend/dist/scripts/prompt-reliability-trend.js"
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.19.19",
    "@types/pg": "^8.20.0",
    "axios": "^1.17.0",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "pg": "^8.21.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "form-data": "4.0.6",
    "esbuild": "^0.25.0",
    "tsx": {
      "esbuild": "^0.25.0"
    }
  }
}
