{
  "name": "kwalify-api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "node scripts/prepare-dist.mjs && node node_modules/typescript/bin/tsc",
    "start": "node backend/dist/server.js",
    "typecheck": "tsc --noEmit",
    "smoke:static": "node scripts/smoke-static.mjs",
    "evaluation:playlists": "npm run build && node backend/dist/scripts/playlist-evaluation-harness.js",
    "benchmark:prompt-reliability": "npm run build && node backend/dist/scripts/prompt-reliability-benchmark.js",
    "regression:prompt-reliability": "npm run build && node backend/dist/scripts/prompt-reliability-regression.js",
    "ci:prompt-reliability": "npm run build && node backend/dist/scripts/prompt-reliability-ci-gate.js",
    "quality:eval": "npm run build && node backend/dist/scripts/playlist-quality-eval.js",
    "quality:stress": "npm run build && node backend/dist/scripts/playlist-stress-report.js",
    "smoke:deploy": "npm run build && node backend/dist/scripts/deploy-smoke.js"
  },
  "dependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.19.19",
    "@types/pg": "^8.20.0",
    "axios": "^1.17.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "pg": "^8.21.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
