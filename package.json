{
  "name": "kwalify-api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "node scripts/prepare-dist.mjs && node node_modules/typescript/bin/tsc",
    "start": "node backend/dist/server.js",
    "typecheck": "tsc --noEmit",
    "smoke:static": "node scripts/smoke-static.mjs",
    "evaluation:playlists": "npm run build && node backend/dist/scripts/playlist-evaluation-harness.js",
    "evaluation:overnight": "npm run build && node backend/dist/scripts/playlist-evaluation-harness.js --benchmark-size 250 --out reports/playlist-evaluation/overnight-live --timeout-ms 120000 --concurrency 1 --delay-ms 2500 --max-http-retries 2 --max-failures 35 --cluster-fail-fast 0 --checkpoint-every 1 --fresh",
    "evaluation:overnight:resume": "npm run build && node backend/dist/scripts/playlist-evaluation-harness.js --benchmark-size 250 --out reports/playlist-evaluation/overnight-live --timeout-ms 120000 --concurrency 1 --delay-ms 2500 --max-http-retries 2 --max-failures 35 --cluster-fail-fast 0 --checkpoint-every 1 --resume",
    "benchmark:prompt-reliability": "npm run build && node backend/dist/scripts/prompt-reliability-benchmark.js",
    "regression:prompt-reliability": "npm run build && node backend/dist/scripts/prompt-reliability-regression.js",
    "regression:playlists": "npm run build && node backend/dist/scripts/playlist-regression-guard.js",
    "ci:prompt-reliability-local": "npm run build && node backend/dist/scripts/prompt-reliability-local-fixtures.js",
    "ci:prompt-reliability": "npm run build && node backend/dist/scripts/prompt-reliability-ci-gate.js",
    "audit:product-behavior": "npm run build && node backend/dist/scripts/playlist-product-behavior-audit.js",
    "audit:system-observability": "npm run build && node backend/dist/scripts/playlist-system-observability-audit.js",
    "quality:eval": "npm run build && node backend/dist/scripts/playlist-quality-eval.js",
    "quality:stress": "npm run build && node backend/dist/scripts/playlist-stress-report.js",
    "smoke:deploy": "npm run build && node backend/dist/scripts/deploy-smoke.js",
    "verify:eval-token": "node scripts/verify-eval-token.mjs",
    "sync:eval-token": "powershell -ExecutionPolicy Bypass -File scripts/sync-eval-token.ps1",
    "harvest:unknown-terms": "npm run build && node backend/dist/scripts/harvest-unknown-terms.js",
    "promote:aliases": "npm run build && node backend/dist/scripts/promote-harvested-aliases.js",
    "promote:aliases:apply": "npm run build && node backend/dist/scripts/promote-harvested-aliases.js -- --apply",
    "coherence:intent": "npm run build && node backend/dist/scripts/coherence-intent-fixtures.js",
    "coherence:playlist": "npm run build && node backend/dist/scripts/coherence-playlist-fixtures.js",
    "coherence:world-boundary": "npm run build && node backend/dist/scripts/coherence-world-boundary-fixtures.js",
    "coherence:uk-hip-hop": "npm run build && node backend/dist/scripts/coherence-uk-hip-hop-fixtures.js",
    "coherence:taxonomy": "npm run build && node backend/dist/scripts/coherence-taxonomy-correlation-fixtures.js",
    "coherence:semantic-collisions": "npm run build && node backend/dist/scripts/coherence-semantic-collision-fixtures.js",
    "coherence:electronic-subgenres": "npm run build && node backend/dist/scripts/coherence-electronic-subgenre-fixtures.js",
    "benchmark:pairwise-signatures": "npm run build && node backend/dist/scripts/pairwise-signature-benchmark.js",
    "backfill:audio-features": "npm run build && node backend/dist/scripts/audio-feature-backfill.js",
    "coherence:recovery-finalization": "npm run build && node backend/dist/scripts/coherence-recovery-finalization-fixtures.js",
    "ci:semantic-scenes": "npm run build && node backend/dist/scripts/semantic-scene-ci-gate.js",
    "regression:coherence-live": "npm run build && node backend/dist/scripts/coherence-live-regression.js",
    "smoke:spotify-user-id": "node scripts/resolve-smoke-spotify-user-id.mjs",
    "validation:production": "npm run build && node backend/dist/scripts/production-validation.js"
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.19.19",
    "@types/pg": "^8.20.0",
    "axios": "^1.17.0",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "pg": "^8.21.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "form-data": "4.0.6",
    "esbuild": "^0.25.0",
    "tsx": {
      "esbuild": "^0.25.0"
    }
  }
}
